# --- project-local, never committed ---
_pm/
# Ignore everything under data/ EXCEPT an empty marker for the cache dir, so the
# path exists in fresh clones / CI build context. The real cached datasets stay
# ignored; the offline demo cache is uploaded only to the Hugging Face Space at
# deploy time.
/data/*
!/data/cache/
/data/cache/*
!/data/cache/.gitkeep
.env

# --- python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
dist/
build/

# --- node / frontend ---
node_modules/
web/dist/
web/.vite/

# --- editors / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- test artifacts ---
playwright-report/
test-results/
