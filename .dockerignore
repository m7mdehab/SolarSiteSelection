# Keep the build context small and reproducible.
.git
.github
_pm/
# Exclude data/ except the demo cache (baked into the image so the preset AOI
# runs offline; in CI this is just the .gitkeep marker, at deploy it is the
# real ~2 MB cache uploaded to the HF Space).
/data/*
!/data/cache
tests/
docs/
*.md
!README.md

# Python caches / local envs
.venv/
**/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Node (frontend is built in-image from source + lockfile)
web/node_modules/
web/dist/
web/.vite/
web/playwright-report/
web/test-results/

# Secrets / local
.env
