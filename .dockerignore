# Keep the build context small and reproducible.
.git
.github
_pm/
# Exclude only the large manual dir; KEEP data/cache so the demo cache is baked
# into the image (the preset AOI runs offline). In CI data/cache is just the
# .gitkeep marker; at deploy it is the real ~2 MB cache uploaded to the HF Space.
# (Do NOT use `/data/*` + `!/data/cache` — Docker's negation drops the files
#  inside the re-included dir, which silently left the cache out of the image.)
data/manual
tests/
docs/
*.md
!README.md

# Python caches / local envs
.venv/
**/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Node (frontend is built in-image from source + lockfile)
web/node_modules/
web/dist/
web/.vite/
web/playwright-report/
web/test-results/

# Secrets / local
.env
