# Copy to .env and fill in. Both are optional — the pipeline has key-free fallbacks.

# OpenTopography API key (https://opentopography.org) — optional secondary DEM source.
# Primary DEM is Copernicus GLO-30 from the public AWS bucket (no key needed).
OPENTOPO_KEY=

# Hugging Face token with write access — only needed for `make deploy` to HF Spaces.
HF_TOKEN=
